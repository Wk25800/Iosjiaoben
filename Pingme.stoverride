script-providers:
  PingMe:
    url: https://raw.githubusercontent.com/Wk25800/Iosjiaoben/main/Pingme.js
    interval: 86400

http-request:
  - match: ^https://api\.pingmeapp\.net/app/queryBalanceAndBonus
    script: PingMe

tasks:
  - name: PingMe签到
    cron: "30 8,20 * * *"
    script: PingMe
    timeout: 30

mitm:
  - api.pingmeapp.net
