name: PingMe
desc: PingMe自动签到
http:
  mitm:
    - "api.pingmeapp.net"
  script:
    - match: ^https:\/\/api\.pingmeapp\.net\/app\/queryBalanceAndBonus
      name: PingMe_Script
      type: request
      require-body: false
      timeout: 10
script-providers:
  PingMe_Script:
    url: https://raw.githubusercontent.com/Wk25800/Iosjiaoben/main/PingMe.js
    interval: 86400
