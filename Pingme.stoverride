http-request:
  - match: https://api.pingmeapp.net/app/queryBalanceAndBonus
    script: PingMe

script-providers:
  PingMe:
    url: https://raw.githubusercontent.com/Wk25800/Iosjiaoben/main/PingMe_Stash.js
    interval: 86400
    interval: 86400

tasks:
  - name: PingMe签到
    script: PingMe
    cron: "30 8,20 * * *"
    timeout: 30

mitm:
  - api.pingmeapp.net
