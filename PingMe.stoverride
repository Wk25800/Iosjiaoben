# PingMe 签到 零报错 Stash 配置
mitm:
  hosts:
    - api.pingmeapp.net

script-providers:
  pingme-script:
    url: https://raw.githubusercontent.com/Wk25800/Iosjiaoben/refs/heads/main/PingMe.js
    interval: 86400

script:
  - match: ^https://api\.pingmeapp\.net/app/queryBalanceAndBonus
    name: pingme-script
    type: request-header
    enable: true

cron:
  script:
    - name: pingme-script
      cron: 30 8,20 * * *
      timeout: 15
      enable: true
