force-request-body: true

script-providers:
  pingme:
    url: https://raw.githubusercontent.com/Wk25800/Iosjiaoben/main/Pingme.js
    interval: 86400

http-request:
  - match: api\.pingmeapp\.net/app/queryBalanceAndBonus
    script: pingme

tasks:
  - cron: "0 8,20 * * *"
    script-provider: pingme
