#!name=PingMe55
#!desc=PingMe

[Script]
PingMe-capture = type=http-request,pattern=^https://api\.pingmeapp\.net/app/queryBalanceAndBonus,script-path=https://raw.githubusercontent.com/Wk25800/Iosjiaoben/refs/heads/main/Surge.js,requires-body=0,max-size=0,debug=0
PingMe-task = type=cron,cronexp=30 8,20 * * *,script-path=https://raw.githubusercontent.com/Wk25800/Iosjiaoben/refs/heads/main/Surge.js,wake-system=1,timeout=120

[MITM]
hostname = %APPEND% api.pingmeapp.net
